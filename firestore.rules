/**
 * @fileoverview Firestore Security Rules for CardCrafter.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for user profiles and user-created cards.
 * Access to match data is restricted to the players involved in the match.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profiles.
 * - /users/{userId}/cards/{cardId}: Stores user-created card data.
 * - /matches/{matchId}: Stores match data for online games.
 *
 * Key Security Decisions:
 * - Users can only read and write their own profiles and cards.
 * - Listing of all users is disallowed.
 * - Match data can only be accessed by the players involved.
 *
 * Denormalization for Authorization:
 * - Match documents contain player1Id and player2Id, enabling rules to authorize access without additional reads.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user profile documents.
     * @path /users/{userId}
     * @allow (create) - Authenticated user can create their own profile if the userId matches their auth UID.
     * @allow (get, update, delete) - Authenticated user can access their own profile.
     * @deny (create) - If the userId does not match the authenticated user's UID.
     * @deny (get, update, delete) - If the userId does not match the authenticated user's UID.
     * @principle Enforces document ownership for user profiles.
     */
    match /users/{userId} {
      // isSignedIn() enforces authentication
      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isExistingOwner(userId);
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }

    /**
     * @description Controls access to user-created card documents.
     * @path /users/{userId}/cards/{cardId}
     * @allow (create) - Authenticated user can create cards under their profile.
     * @allow (get, list, update, delete) - Authenticated user can only access cards under their own profile.
     * @deny (create) - If the userId does not match the authenticated user's UID.
     * @deny (get, list, update, delete) - If the userId does not match the authenticated user's UID.
     * @principle Enforces document ownership for user-created cards.
     */
    match /users/{userId}/cards/{cardId} {
      allow get: if isSignedIn() && isOwner(userId);
      allow list: if isSignedIn() && isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isExistingOwner(userId);
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }

    /**
     * @description Controls access to match documents.
     * @path /matches/{matchId}
     * @allow (get, list) - If the authenticated user is one of the players in the match.
     * @allow (create) - If the authenticated user is one of the players in the match and the match data is valid.
     * @allow (update, delete) - If the authenticated user is one of the players in the match and the match exists.
     * @deny (get, list) - If the authenticated user is not one of the players in the match.
     * @deny (create) - If the authenticated user is not one of the players in the match.
     * @deny (update, delete) - If the authenticated user is not one of the players in the match.
     * @principle Restricts match data access to participating players.
     */
    match /matches/{matchId} {
      allow get: if isSignedIn() && isPlayerInMatch(resource.data.player1Id, resource.data.player2Id);
      allow list: if isSignedIn() && isPlayerInMatch(resource.data.player1Id, resource.data.player2Id);
      allow create: if isSignedIn() && (request.auth.uid == request.resource.data.player1Id || request.auth.uid == request.resource.data.player2Id);
      allow update: if isSignedIn() && isExistingPlayerInMatch(resource.data.player1Id, resource.data.player2Id);
      allow delete: if isSignedIn() && isExistingPlayerInMatch(resource.data.player1Id, resource.data.player2Id);
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
        return isSignedIn() && isOwner(userId) && resource != null;
    }

    function isPlayerInMatch(player1Id, player2Id) {
        return request.auth.uid == player1Id || request.auth.uid == player2Id;
    }

    function isExistingPlayerInMatch(player1Id, player2Id) {
        return isSignedIn() && isPlayerInMatch(player1Id, player2Id) && resource != null;
    }
  }
}