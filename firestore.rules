
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /cards/{cardId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /decks/{deckId} {
      allow read, write: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
    match /trades/{tradeId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (request.resource.data.offerorId == request.auth.uid || request.resource.data.offereeId == request.auth.uid);
    }
    match /guilds/{guildId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && request.resource.data.leaderId == request.auth.uid;
    }
    match /guilds/{guildId}/messages/{messageId} {
      allow read: if true;
      allow create: if request.auth != null;
    }
    match /replays/{replayId} {
      allow read, write: if true;
    }
    match /battleRooms/{roomId} {
      allow read, write: if request.auth != null;
    }
  }
}
