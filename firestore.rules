/**
 * @fileoverview Firestore Security Rules for CardCrafter application.
 *
 * Core Philosophy:
 * This ruleset enforces a user-ownership model for user profiles and user-created cards,
 * and a shared access model for online matches and associated chat messages. It emphasizes
 * authorization independence through data denormalization.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile information.
 * - /users/{userId}/cards/{cardId}: Stores user-created cards.
 * - /matches/{matchId}: Stores match data between two players.
 * - /matches/{matchId}/chatMessages/{chatMessageId}: Stores chat messages for a match.
 *
 * Key Security Decisions:
 * - Users can only read and write their own profiles and cards.
 * - Only players in a match can read and write chat messages for that match.
 * - Listing of user-created cards is allowed only to the owner.
 * - Listing of users is not allowed.
 *
 * Denormalization for Authorization:
 * - The /matches/{matchId}/chatMessages/{chatMessageId} collection denormalizes the
 *   'matchId', 'player1Id', and 'player2Id' from the parent 'match' document onto
 *   each chat message. This allows security rules to directly check if the requesting
 *   user is one of the players in the match without needing to perform additional reads.
 *
 * Structural Segregation:
 * - User-generated cards are stored in a user-specific subcollection, ensuring clear
 *   ownership and simplifying access control.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user profile information.
     * @path /users/{userId}
     * @allow (create) - Authenticated user can create their own profile.
     * @allow (get, update, delete) - Authenticated user can only access their own profile data.
     * @deny (create) - Creating a profile with a different user ID than the authenticated user ID.
     * @deny (get, update, delete) - Accessing another user's profile data.
     * @principle Enforces document ownership for user profiles.
     */
    match /users/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if false; // User listing is not permitted.
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to cards created by a user.
     * @path /users/{userId}/cards/{cardId}
     * @allow (create, get, list, update, delete) - Authenticated user can only manage their own cards.
     * @deny (create, get, list, update, delete) - Accessing or modifying another user's cards.
     * @principle Enforces document ownership for user-created cards.
     */
    match /users/{userId}/cards/{cardId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to match data.
     * @path /matches/{matchId}
     * @allow (get, list) - Everyone can read match data.
     * @allow (create, update, delete) - Only the application can manage match data.
     * @principle Public read access with restricted writes.
     */
    match /matches/{matchId} {
      allow get, list: if true;
      allow create, update, delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Controls access to chat messages within a match.
     * @path /matches/{matchId}/chatMessages/{chatMessageId}
     * @allow (create) - Players in the match can create chat messages.
     * @allow (get, list) - Players in the match can read chat messages.
     * @deny (create) - Users not in the match cannot create chat messages.
     * @deny (get, list) - Users not in the match cannot read chat messages.
     * @principle Enforces shared access based on match participation.
     */
    match /matches/{matchId}/chatMessages/{chatMessageId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isPlayerInMatch(matchId) {
        return get(/databases/$(database)/documents/matches/$(matchId)).data.player1Id == request.auth.uid
            || get(/databases/$(database)/documents/matches/$(matchId)).data.player2Id == request.auth.uid;
      }

      allow get, list: if isSignedIn() && isPlayerInMatch(matchId);
      allow create: if isSignedIn() && isPlayerInMatch(matchId);
      allow update, delete: if false;
    }
  }
}