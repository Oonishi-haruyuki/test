# Firebase Web App config
# Firebase Console > Project settings > General > Your apps > Web app config から取得してください。
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id

# Google AI Studio / Genkit
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: override the Genkit model.
# GENKIT_MODEL=googleai/gemini-2.0-flash

# Optional: return mock decks when Gemini quota/auth fails during development.
# ENABLE_DECK_MOCK_FALLBACK=true
