
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Represents a user's public profile information.",
      "type": "object",
      "properties": {
        "loginId": {
          "type": "string",
          "description": "The user's unique login identifier."
        },
        "rating": {
          "type": "number",
          "description": "The user's ELO rating for ranked matches. Defaults to 1000."
        },
        "lastMatchDate": {
            "type": "string",
            "format": "date-time",
            "description": "The timestamp of the user's last completed match."
        },
        "guildId": {
          "type": "string",
          "description": "The ID of the guild the user belongs to."
        }
      }
    },
    "Card": {
      "title": "Card",
      "description": "Represents a single card in the trading card game.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the card."
        },
        "theme": {
          "type": "string",
          "description": "The theme of the card (e.g., fantasy, sci-fi).",
          "enum": ["fantasy", "sci-fi", "modern", "custom"]
        },
        "name": {
          "type": "string",
          "description": "The name of the card."
        },
        "manaCost": {
          "type": "number",
          "description": "The mana cost to play the card."
        },
        "attack": {
          "type": "number",
          "description": "The attack power of the card (for creatures)."
        },
        "defense": {
          "type": "number",
          "description": "The defense/health of the card (for creatures)."
        },
        "cardType": {
          "type": "string",
          "description": "The type of the card.",
          "enum": ["creature", "spell", "artifact", "land"]
        },
        "rarity": {
          "type": "string",
          "description": "The rarity of the card.",
          "enum": ["common", "uncommon", "rare", "mythic"]
        },
        "abilities": {
          "type": "string",
          "description": "The special abilities or rules text of the card."
        },
        "flavorText": {
          "type": "string",
          "description": "The thematic or story text of the card."
        },
        "imageUrl": {
          "type": "string",
          "format": "uri",
          "description": "The URL for the card's artwork."
        },
        "imageHint": {
          "type": "string",
          "description": "A hint for generating the card's image."
        },
        "frameImageUrl": {
          "type": "string",
          "format": "uri",
          "description": "The URL for the card's custom frame."
        }
      },
      "required": ["name", "manaCost", "cardType", "rarity", "imageUrl"]
    },
    "Game": {
      "title": "Game",
      "description": "Represents the state of an online card game session.",
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["waiting", "active", "finished"],
          "description": "The current status of the game."
        },
        "player1Id": {
          "type": "string",
          "description": "The UID of the first player."
        },
        "player2Id": {
          "type": "string",
          "description": "The UID of the second player."
        },
        "player1LoginId": {
          "type": "string",
          "description": "The login ID of player 1."
        },
        "player2LoginId": {
          "type": "string",
          "description": "The login ID of player 2."
        },
        "player1Health": {
          "type": "number",
          "description": "The current health of player 1."
        },
        "player2Health": {
          "type": "number",
          "description": "The current health of player 2."
        },
        "turn": {
          "type": "number",
          "description": "The current turn number."
        },
        "activePlayerId": {
          "type": "string",
          "description": "The UID of the player whose turn it is."
        },
        "winnerId": {
          "type": "string",
          "description": "The UID of the winning player, if the game is finished."
        },
        "lastAction": {
          "type": "string",
          "description": "A description of the last action taken."
        },
        "lastEmote": {
          "type": "object",
          "properties": {
            "id": { "type": "string" },
            "senderId": { "type": "string" }
          },
          "description": "The last emote sent in the game."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the game was created."
        },
        "player1Deck": {
          "type": "array",
          "items": { "$ref": "#/entities/Card" }
        },
        "player2Deck": {
          "type": "array",
          "items": { "$ref": "#/entities/Card" }
        },
        "player1Board": {
          "type": "array",
          "items": { "$ref": "#/entities/Card" }
        },
        "player2Board": {
          "type": "array",
          "items": { "$ref": "#/entities/Card" }
        },
         "player1Hand": {
          "type": "array",
          "items": { "$ref": "#/entities/Card" }
        },
        "player2Hand": {
          "type": "array",
          "items": { "$ref": "#/entities/Card" }
        },
        "player1Mana": {
            "type": "number",
            "description": "Current mana for player 1."
        },
        "player2Mana": {
            "type": "number",
            "description": "Current mana for player 2."
        },
        "player1MaxMana": {
          "type": "number"
        },
        "player2MaxMana": {
            "type": "number"
        }
      }
    },
    "TradeOffer": {
      "title": "Trade Offer",
      "description": "Represents a trade offer between two users.",
      "type": "object",
      "properties": {
        "offerorId": { "type": "string", "description": "The UID of the user making the offer." },
        "offerorLoginId": { "type": "string", "description": "The login ID of the offeror." },
        "offereeId": { "type": "string", "description": "The UID of the user receiving the offer." },
        "offereeLoginId": { "type": "string", "description": "The login ID of the offeree." },
        "offeredCards": { "type": "array", "items": { "$ref": "#/entities/Card" } },
        "requestedCards": { "type": "array", "items": { "$ref": "#/entities/Card" } },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Guild": {
      "title": "Guild",
      "description": "Represents a player guild.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the guild." },
        "description": { "type": "string", "description": "A short description of the guild." },
        "leaderId": { "type": "string", "description": "The UID of the user who created the guild." },
        "memberIds": { "type": "array", "items": { "type": "string" }, "description": "A list of UIDs of the guild members." },
        "createdAt": { "type": "string", "format": "date-time" },
        "activityTime": { "type": "string", "description": "The typical activity time for the guild." },
        "genderRatio": { "type": "string", "description": "The gender ratio of the guild." },
        "notes": { "type": "string", "description": "Additional notes or rules for the guild." }
      },
      "required": ["name", "leaderId", "memberIds"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "Represents a single message in a guild chat.",
      "type": "object",
      "properties": {
        "guildId": { "type": "string" },
        "userId": { "type": "string" },
        "userLoginId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Replay": {
      "title": "Game Replay",
      "description": "Stores the full history of a game for later playback.",
      "type": "object",
      "properties": {
        "player1Id": { "type": "string" },
        "player2Id": { "type": "string" },
        "player1LoginId": { "type": "string" },
        "player2LoginId": { "type": "string" },
        "winnerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "history": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "log": { "type": "string" },
              "player1Health": { "type": "number" },
              "player2Health": { "type": "number" },
              "player1Mana": { "type": "number" },
              "player2Mana": { "type": "number" },
              "player1MaxMana": { "type": "number" },
              "player2MaxMana": { "type": "number" },
              "player1Hand": { "type": "array", "items": { "$ref": "#/entities/Card" } },
              "player2Hand": { "type": "array", "items": { "$ref": "#/entities/Card" } },
              "player1Board": { "type": "array", "items": { "$ref": "#/entities/Card" } },
              "player2Board": { "type": "array", "items": { "$ref": "#/entities/Card" } }
            }
          }
        }
      }
    },
    "Tournament": {
        "title": "Tournament",
        "description": "Represents a user-created tournament event.",
        "type": "object",
        "properties": {
            "name": { "type": "string" },
            "organizerId": { "type": "string" },
            "organizerLoginId": { "type": "string" },
            "status": { "type": "string", "enum": ["registering", "bracket-generated", "active", "finished"] },
            "entryFee": { "type": "number" },
            "prizePool": { "type": "number" },
            "startTime": { "type": "string", "format": "date-time" },
            "deckType": { "type": "string", "enum": ["user-created", "ai-generated"] },
            "participants": { "type": "array", "items": { "$ref": "#/entities/TournamentParticipant" } },
            "bracket": { "type": "object", "description": "Tournament bracket structure" },
            "createdAt": { "type": "string", "format": "date-time" }
        }
    },
    "TournamentParticipant": {
        "title": "Tournament Participant",
        "description": "Represents a single participant in a tournament.",
        "type": "object",
        "properties": {
            "userId": { "type": "string" },
            "userLoginId": { "type": "string" },
            "deckId": { "type": "string" },
            "deckName": { "type": "string" },
            "deckCards": { "type": "array", "items": { "$ref": "#/entities/Card" } }
        }
    }
  },
  "auth": {
    "providers": ["email", "google"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/UserProfile"
      },
      "description": "Stores public information about a user, like their display name and rating."
    },
    "/games/{gameId}": {
      "schema": {
        "$ref": "#/entities/Game"
      },
      "description": "Stores individual game sessions for online battles."
    },
    "/trades/{tradeId}": {
      "schema": {
        "$ref": "#/entities/TradeOffer"
      },
      "description": "Stores trade offers between users."
    },
    "/guilds/{guildId}": {
      "schema": { "$ref": "#/entities/Guild" },
      "description": "Stores guild information."
    },
    "/guilds/{guildId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/ChatMessage" },
      "description": "Stores chat messages for a guild."
    },
    "/replays/{replayId}": {
      "schema": { "$ref": "#/entities/Replay" },
      "description": "Stores game replay data."
    },
    "/tournaments/{tournamentId}": {
        "schema": { "$ref": "#/entities/Tournament" },
        "description": "Stores user-created tournament data."
    }
  }
}
